{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": ".",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "types": ["vitest/globals"]
    },
    "include": [
        "*.ts",
        "utils/**/*.ts",
        "config/**/*.ts",
        "render/**/*.ts",
        "types/**/*.ts",
        "test/**/*.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
