{
    "name": "flightradar24-card",
    "version": "1.0.0",
    "type": "module",
    "description": "Home Assistant custom card for Flightradar24 integration",
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@playwright/browser-chromium": "^1.58.2",
        "@rollup/plugin-commonjs": "^29.0.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.1.0",
        "@vitest/browser": "^4.1.2",
        "@vitest/browser-playwright": "^4.1.2",
        "@vitest/coverage-v8": "^4.0.0",
        "eslint": "^9.0.0",
        "globals": "^16.0.0",
        "jsdom": "^26.0.0",
        "playwright": "^1.58.2",
        "rollup": "^4.52.5",
        "rollup-plugin-terser": "^7.0.2",
        "tslib": "^2.8.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.0"
    },
    "scripts": {
        "build": "rollup -c",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:browser": "vitest run --config vitest.browser.config.ts",
        "test:browser:watch": "vitest --config vitest.browser.config.ts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit"
    }
}
